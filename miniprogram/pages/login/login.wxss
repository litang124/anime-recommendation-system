/* pages/login/login.wxss */
.login-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f03d6d 0%, #ff8a65 100%);
  display: flex;
  flex-direction: column;
  padding: 0 40rpx;
}

/* Logo 区域 */
.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
  padding-bottom: 60rpx;
}

.logo-icon {
  font-size: 120rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-top: 24rpx;
}

.app-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 12rpx;
}

/* 内容区域 */
.login-content {
  flex: 1;
  background: #fff;
  border-radius: 40rpx 40rpx 0 0;
  padding: 60rpx 40rpx;
  margin-top: 40rpx;
}

.welcome-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 50rpx;
}

.feature-list {
  padding: 0 20rpx;
}

.feature-item {
  font-size: 32rpx;
  color: #666;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.feature-item:last-child {
  border-bottom: none;
}

/* 按钮区域 */
.button-area {
  background: #fff;
  padding: 40rpx;
  padding-bottom: 80rpx;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-btn.primary {
  background: linear-gradient(135deg, #f03d6d 0%, #ff8a65 100%);
  color: #fff;
  border: none;
}

.login-btn.secondary {
  background: #fff;
  color: #f03d6d;
  border: 2rpx solid #f03d6d;
  margin-top: 24rpx;
}

.agreement {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 40rpx;
}

.link {
  color: #f03d6d;
}
