<view class="container">
  <view class="title">调试页面</view>
  
  <view class="info-card">
    <text class="info-label">当前API地址：</text>
    <text class="info-value">{{apiBase}}</text>
  </view>
  
  <view class="btn-group">
    <button type="primary" bindtap="testConnection" loading="{{testing}}">
      测试服务器连接
    </button>
    <button type="default" bindtap="clearStorage">
      清除缓存
    </button>
    <button type="warn" bindtap="reloadApp">
      重启小程序
    </button>
  </view>
  
  <view class="results">
    <view class="result-title">测试结果</view>
    
    <view wx:if="{{connectionResult}}" class="result-item success">
      <text class="result-text">{{connectionResult}}</text>
    </view>
    
    <view wx:if="{{error}}" class="result-item error">
      <text class="result-text">{{error}}</text>
    </view>
    
    <view wx:if="{{networkInfo}}" class="info-card">
      <text class="info-label">网络状态：</text>
      <text class="info-value">{{networkInfo}}</text>
    </view>
  </view>
</view>