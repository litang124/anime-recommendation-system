/* pages/test-network/test-network.wxss */
.test-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 头部 */
.test-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 30rpx;
  text-align: center;
}

.header-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  display: block;
}

.header-subtitle {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 12rpx;
  display: block;
}

/* 环境信息 */
.info-section {
  padding: 20rpx;
}

.info-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 26rpx;
  color: #333;
  max-width: 60%;
  text-align: right;
  word-break: break-all;
}

.info-value.success {
  color: #52c41a;
}

.info-value.warning {
  color: #faad14;
}

/* 统计区域 */
.stats-section {
  display: flex;
  justify-content: space-around;
  background: #fff;
  margin: 0 20rpx 20rpx;
  padding: 24rpx;
  border-radius: 16rpx;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.stat-value.success {
  color: #52c41a;
}

.stat-value.error {
  color: #f5222d;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

/* 操作按钮区域 */
.action-section {
  padding: 0 20rpx 20rpx;
}

.test-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.test-btn.primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.test-btn.warning {
  background: #fff;
  color: #faad14;
  border: 2rpx solid #faad14;
}

.btn-group {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.test-btn.small {
  flex: 1;
  height: 72rpx;
  font-size: 26rpx;
  background: #fff;
  color: #666;
  border: 2rpx solid #e8e8e8;
}

.test-btn.small:active {
  background: #f5f5f5;
}

/* 结果区域 */
.results-section {
  padding: 0 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.results-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 结果卡片 */
.result-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.result-card.success {
  border-left: 6rpx solid #52c41a;
}

.result-card.error {
  border-left: 6rpx solid #f5222d;
}

.result-header {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.result-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.result-title-wrap {
  flex: 1;
}

.result-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  display: block;
}

.result-endpoint {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
  display: block;
}

.result-duration {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
}

.result-body {
  padding: 16rpx 20rpx;
  display: flex;
  gap: 32rpx;
  background: #fafafa;
}

.result-detail {
  display: flex;
  align-items: center;
}

.detail-label {
  font-size: 24rpx;
  color: #999;
  margin-right: 8rpx;
}

.detail-value {
  font-size: 24rpx;
  color: #333;
}

.result-error {
  padding: 16rpx 20rpx;
  background: #fff2f0;
}

.error-text {
  font-size: 24rpx;
  color: #f5222d;
  word-break: break-all;
}

/* 响应预览 */
.response-preview {
  padding: 16rpx 20rpx;
  background: #fafafa;
  border-top: 1rpx solid #f5f5f5;
}

.preview-toggle {
  font-size: 24rpx;
  color: #667eea;
}

.response-data {
  padding: 16rpx 20rpx;
  background: #f6f8fa;
  max-height: 400rpx;
  overflow: auto;
}

.response-text {
  font-size: 22rpx;
  color: #666;
  font-family: monospace;
  word-break: break-all;
  white-space: pre-wrap;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
  background: #fff;
  border-radius: 16rpx;
}

.empty-icon {
  font-size: 120rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-top: 30rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #999;
  margin-top: 16rpx;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
  background: #fff;
  border-radius: 16rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #999;
  margin-top: 20rpx;
}
