/* pages/settings/notification/notification.wxss */
.notification-container {
  min-height: 100vh;
  background: #f5f5f5;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin: 40rpx 0 20rpx;
}

.notification-list {
  margin: 0 20rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.notification-item {
  display: flex;
  align-items: center;
  padding: 30rpx 24rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.notification-item:last-child {
  border-bottom: none;
}

.notification-content {
  flex: 1;
}

.notification-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  display: block;
}

.notification-desc {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
  display: block;
}

.notification-toggle {
  width: 80rpx;
  height: 40rpx;
  position: relative;
}

.toggle-switch {
  width: 80rpx;
  height: 40rpx;
  background: #e0e0e0;
  border-radius: 20rpx;
  position: relative;
  transition: background 0.3s;
}

.toggle-switch.on {
  background: #f03d6d;
}

.toggle-circle {
  width: 32rpx;
  height: 32rpx;
  background: #fff;
  border-radius: 50%;
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  transition: transform 0.3s;
  box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.2);
}

.toggle-circle.on {
  transform: translateX(40rpx);
}

.back-btn {
  text-align: center;
  padding: 40rpx 0;
}

.back-text {
  font-size: 28rpx;
  color: #666;
}