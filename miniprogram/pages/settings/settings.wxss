/* pages/settings/settings.wxss */
.settings-container {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 用户卡片 */
.user-card {
  margin: 20rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
}

.user-header {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.15);
}

.user-info {
  flex: 1;
  margin-left: 30rpx;
}

.user-nickname {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.user-id {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

.logout-btn {
  padding: 20rpx 0;
  text-align: center;
  border-top: 2rpx solid #f0f0f0;
}

.logout-text {
  font-size: 28rpx;
  color: #f03d6d;
  font-weight: 500;
}

/* 设置列表 */
.settings-list {
  margin: 0 20rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.setting-item {
  display: flex;
  align-items: center;
  padding: 30rpx 24rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-icon {
  font-size: 40rpx;
  margin-right: 24rpx;
}

.setting-content {
  flex: 1;
}

.setting-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  display: block;
}

.setting-desc {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
  display: block;
}

.setting-arrow {
  font-size: 36rpx;
  color: #999;
}

/* 未登录提示 */
.login-prompt {
  text-align: center;
  padding: 100rpx 40rpx;
}

.prompt-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 40rpx;
}

.login-btn {
  background: linear-gradient(135deg, #f03d6d 0%, #ff8a65 100%);
  color: #fff;
  font-size: 32rpx;
  padding: 24rpx 80rpx;
  border-radius: 40rpx;
  border: none;
}

/* 页面标题 */
.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin: 40rpx 0 20rpx;
}