/* pages/recommend/recommend.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f03d6d 0%, #ff8a65 100%);
  padding: 20rpx;
}

/* 登录提示 */
.login-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  margin-top: 200rpx;
}

.tip-text {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 40rpx;
}

.login-btn {
  background: linear-gradient(135deg, #f03d6d 0%, #ff8a65 100%);
  color: white;
  padding: 20rpx 60rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
}

/* 加载中 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 40rpx;
  color: white;
  font-size: 28rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: white;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 用户画像卡片 */
.profile-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
}

.profile-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.profile-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.profile-stats {
  display: flex;
  gap: 30rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #f03d6d;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 5rpx;
}

/* 偏好标签 */
.preference-section {
  margin-top: 20rpx;
}

.section-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 15rpx;
  display: block;
}

.tag-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.tag-item {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.tag-name {
  font-size: 26rpx;
  color: #333;
  width: 120rpx;
  flex-shrink: 0;
}

.tag-bar {
  flex: 1;
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
}

.tag-fill {
  height: 100%;
  background: linear-gradient(90deg, #f03d6d 0%, #ff8a65 100%);
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

.tag-weight {
  font-size: 24rpx;
  color: #f03d6d;
  width: 70rpx;
  text-align: right;
}

/* 推荐列表标题 */
.recommend-header {
  text-align: center;
  margin: 30rpx 0;
}

.recommend-title {
  font-size: 40rpx;
  font-weight: bold;
  color: white;
  display: block;
}

.recommend-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 10rpx;
  display: block;
}

/* 推荐列表 */
.recommend-list {
  display: flex;
  flex-direction: column;
  gap: 25rpx;
}

.anime-card {
  display: flex;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.1);
  position: relative;
  transition: transform 0.2s;
}

.anime-card:active {
  transform: scale(0.98);
}

.anime-card.top3 {
  border: 3rpx solid #ffd700;
}

/* 排名标识 */
.rank-badge {
  position: absolute;
  top: 0;
  left: 0;
  background: linear-gradient(135deg, #ffd700 0%, #ffaa00 100%);
  color: white;
  padding: 10rpx 20rpx;
  border-radius: 0 0 20rpx 0;
  font-size: 24rpx;
  font-weight: bold;
  z-index: 10;
}

.rank-number {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  width: 50rpx;
  height: 50rpx;
  background: rgba(0, 0, 0, 0.5);
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  z-index: 10;
}

/* 封面图 */
.anime-cover {
  width: 220rpx;
  height: 300rpx;
  flex-shrink: 0;
  background: #f0f0f0;
}

/* 动漫信息 */
.anime-info {
  flex: 1;
  padding: 25rpx;
  display: flex;
  flex-direction: column;
}

.anime-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
  line-height: 1.4;
}

.anime-meta {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 15rpx;
}

.rating {
  display: flex;
  align-items: baseline;
}

.rating-score {
  font-size: 40rpx;
  font-weight: bold;
  color: #ff6b6b;
}

.rating-total {
  font-size: 24rpx;
  color: #999;
  margin-left: 5rpx;
}

.status-badge {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  background: #f0f0f0;
  color: #666;
}

.status-badge.ongoing {
  background: #e3f2fd;
  color: #1976d2;
}

.status-badge.completed {
  background: #e8f5e9;
  color: #388e3c;
}

/* 标签 */
.tag-container {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 15rpx;
}

.anime-tag {
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, #f03d6d 0%, #ff8a65 100%);
  color: white;
  border-radius: 20rpx;
  font-size: 22rpx;
}

/* 简介 */
.anime-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 15rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 热度 */
.heat-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: auto;
}

.heat-icon {
  font-size: 28rpx;
}

.heat-value {
  font-size: 26rpx;
  color: #ff6b6b;
  font-weight: bold;
}

.heat-label {
  font-size: 24rpx;
  color: #999;
}

/* 底部提示 */
.footer-tip {
  text-align: center;
  padding: 40rpx;
  color: rgba(255, 255, 255, 0.7);
  font-size: 26rpx;
}

/* 推荐理由 */
.recommend-reason {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  margin-bottom: 15rpx;
  padding: 15rpx 18rpx;
  background: linear-gradient(135deg, #e3f2fd 0%, #f3e5f5 100%);
  border-radius: 12rpx;
  border-left: 5rpx solid #f03d6d;
  box-shadow: 0 2rpx 8rpx rgba(240, 61, 109, 0.1);
}

.reason-icon {
  font-size: 34rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.reason-text {
  font-size: 26rpx;
  color: #d81b60;
  font-weight: 500;
  line-height: 1.6;
  flex: 1;
}

/* 评分控件 */
.rating-control {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 15rpx;
  padding: 10rpx 15rpx;
  background: #fff;
  border-radius: 12rpx;
  border: 1rpx solid #e0e0e0;
}

.rating-label {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
}

.stars {
  display: flex;
  gap: 5rpx;
}

.star {
  font-size: 32rpx;
  color: #ccc;
  transition: all 0.2s;
}

.star.active {
  color: #ff6b6b;
}

.star:hover {
  color: #ff6b6b;
}