
/* 页面容器 */
.container {
  min-height: 100vh;
  background: #f8f9fa;
}

/* 搜索栏（固定定位） */
.search-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 999;
  padding: 30rpx 30rpx !important;
  background: linear-gradient(135deg, #f03d6d, #ff8a65);
}

/* 搜索栏 */
.search-bar {
  padding: 30rpx 30rpx !important;
  background: linear-gradient(135deg, #f03d6d, #ff8a65);
}

.search-input {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 50rpx;
  padding: 20rpx 30rpx;
  display: flex;
  align-items: center;
  backdrop-filter: blur(10px);
}

.search-input icon {
  margin-right: 10rpx;
}

.placeholder {
  color: #999;
  font-size: 28rpx;
}

/* 用户信息 */
.user-info {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: white;
  margin: 20rpx 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.08);
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  border: 3rpx solid #f0f0f0;
}

.user-detail {
  flex: 1;
}

.nickname {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 5rpx;
}

.welcome {
  font-size: 26rpx;
  color: #666;
}

.notification-btn {
  width: 60rpx;
  height: 60rpx;
  background: linear-gradient(135deg, #f03d6d, #ff8a65);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
}

/* 区域标题 */
.section {
  margin-top: 40rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 30rpx;
  margin-bottom: 20rpx;
}

.title-group {
  display: flex;
  align-items: center;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-left: 10rpx;
}

.section-icon {
  font-size: 32rpx;
}

.section-more {
  font-size: 26rpx;
  color: #f03d6d;
}



.card-tag {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  background: rgba(240, 61, 109, 0.9);
  color: white;
  padding: 8rpx 15rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  z-index: 2;
}

.recommend-card .cover {
  width: 280rpx;
  height: 350rpx;
}

.card-info {
  padding: 20rpx;
}

.card-info .title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.score {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #ff9500;
}

.tags {
  font-size: 22rpx;
  color: #666;
  background: #f5f5f5;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
}

/* 热门网格 */
.hot-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin: 0;
  padding: 0 30rpx;
  min-height: 400rpx;
}

.hot-item {
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 5rpx 20rpx rgba(0, 0, 0, 0.05);
}

.hot-item .cover {
  width: 100%;
  height: 280rpx;
}

.hot-info {
  padding: 20rpx;
  flex-direction: column;
}

.hot-info .title {
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  word-break: break-word;
}

.stats {
  display: flex;
  gap: 15rpx;
  margin-bottom: 10rpx;
}

.stat-item {
  display: flex;
  align-items: center;
  font-size: 22rpx;
  color: #666;
}

.stat-icon {
  font-size: 24rpx;
  margin-right: 6rpx;
}

.status {
  font-size: 22rpx;
  color: #4cd964;
  background: #e8f5e9;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  display: inline-block;
}

/* 更新列表 */
.schedule-list {
  padding: 0 30rpx;
}

.schedule-item {
  display: flex;
  align-items: center;
  background: white;
  border-radius: 16rpx;
  padding: 25rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 5rpx 20rpx rgba(0, 0, 0, 0.05);
  position: relative;
}

.time-badge {
  position: absolute;
  top: -10rpx;
  left: 25rpx;
  background: #4cd964;
  color: white;
  padding: 8rpx 15rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.schedule-item .cover {
  width: 120rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-right: 25rpx;
}

.schedule-info {
  flex: 1;
}

.schedule-info .title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.episode-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.episode {
  font-size: 24rpx;
  color: #f03d6d;
  background: #ffeef2;
  padding: 6rpx 12rpx;
  border-radius: 6rpx;
}

.platform {
  font-size: 24rpx;
  color: #666;
}

.progress-bar {
  height: 8rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress {
  height: 100%;
  background: linear-gradient(90deg, #f03d6d, #ff8a65);
  border-radius: 4rpx;
}

.remind-btn {
  margin-left: 20rpx;
  background: transparent;
  border: 2rpx solid #f03d6d;
  color: #f03d6d;
  border-radius: 20rpx;
  font-size: 24rpx;
  padding: 10rpx 20rpx;
}

/* 底部导航 */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-around;
  background: white;
  padding: 20rpx 0;
  border-top: 1rpx solid #f0f0f0;
  z-index: 100;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.nav-icon {
  font-size: 40rpx;
  margin-bottom: 5rpx;
}

.nav-item text {
  font-size: 22rpx;
  color: #666;
}

/* 加载状态 */
.loading-container {
  padding: 100rpx 0;
  text-align: center;
}

.loading-gif {
  width: 100rpx;
  height: 100rpx;
  margin-bottom: 20rpx;
}

/* 空状态 */
.empty-container {
  padding: 100rpx 30rpx;
  text-align: center;
}

.empty-img {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.7;
}

.empty-title {
  font-size: 32rpx;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 30rpx;
}

.login-btn {
  background: linear-gradient(135deg, #f03d6d, #ff8a65);
  color: white;
  border-radius: 50rpx;
  padding: 25rpx 60rpx;
  font-size: 28rpx;
}