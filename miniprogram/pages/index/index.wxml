<view class="container">
  <!-- 顶部搜索栏 -->
  <view class="search-bar" bindtap="navigateToSearch" style="padding: 10rpx 210rpx;">
    <view class="search-input">
      <icon type="search" size="18" color="#999" />
      <text class="placeholder">搜索动漫...</text>
    </view>
  </view>

  <!-- 用户信息 -->
  <view class="user-info" wx:if="{{userInfo}}" bindtap="navigateToProfile">
    <image class="avatar" src="{{userInfo.avatarUrl || '/images/logo.png'}}" mode="aspectFill" />
    <view class="user-detail">
      <text class="nickname">{{userInfo.nickname}}</text>
      <text class="welcome">发现你感兴趣的动漫</text>
    </view>
    <button class="notification-btn">
      <icon type="info" size="20" color="#fff" />
    </button>
  </view>


  <!-- 热门动漫 -->
  <view class="section" wx:if="{{hotAnime.length > 0}}">
    <view class="section-header">
      <view class="title-group">
        <text class="section-icon">🔥</text>
        <text class="section-title">热门动漫</text>
      </view>
    </view>
    <view class="hot-grid">
      <block wx:for="{{hotAnime}}" wx:key="id">
        <view class="hot-item" data-id="{{item.id}}" bindtap="navigateToDetail">
          <image class="cover" src="{{item.coverUrl || '/assets/images/default-cover.png'}}" mode="aspectFill" />
          <view class="hot-info">
            <text class="title">{{item.title}}</text>
            <view class="stats">
              <view class="stat-item">
                <text class="stat-icon">⭐</text>
                <text>{{item.score}}</text>
              </view>
              <view class="stat-item">
                <text class="stat-icon">🔥</text>
                <text>{{item.heat}}</text>
              </view>
            </view>
            <text class="status">{{item.status}}</text>
          </view>
        </view>
      </block>
    </view>
  </view>

  <!-- 今日更新 -->
  <view class="section" wx:if="{{newSchedules.length > 0}}">
    <view class="section-header">
      <view class="title-group">
        <text class="section-icon">🕐</text>
        <text class="section-title">今日更新</text>
      </view>
      <text class="section-more" bindtap="navigateToSchedule">查看全部</text>
    </view>
    <view class="schedule-list">
      <block wx:for="{{newSchedules}}" wx:key="id">
        <view class="schedule-item" data-id="{{item.animeId}}" bindtap="navigateToDetail">
          <view class="time-badge">
            <text>{{item.airTime}}</text>
          </view>
          <image class="cover" src="{{item.animeCover || '/assets/images/default-cover.png'}}" mode="aspectFill" />
          <view class="schedule-info">
            <text class="title">{{item.animeTitle}}</text>
            <view class="episode-info">
              <text class="episode">第{{item.episode}}集</text>
              <text class="platform">{{item.platform}}</text>
            </view>
            <view class="progress-bar">
              <view class="progress" style="width: {{item.progress}}"></view>
            </view>
          </view>
          <button class="remind-btn" size="mini" data-id="{{item.id}}">提醒</button>
        </view>
      </block>
    </view>
  </view>

  <!-- 底部功能区 -->
  <view class="bottom-nav">
    <view class="nav-item" bindtap="navigateToSchedule">
      <text class="nav-icon">📅</text>
      <text>新番日历</text>
    </view>
    <view class="nav-item" bindtap="navigateToCommunity">
      <text class="nav-icon">💬</text>
      <text>评分社区</text>
    </view>
    <view class="nav-item" bindtap="testApiConnection">
      <text class="nav-icon">📡</text>
      <text>网络测试</text>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-container" wx:if="{{loading}}">
    <image class="loading-gif" src="/assets/images/loading.gif" />
    <text>加载中...</text>
  </view>

  <!-- 空状态 -->
  <view class="empty-container" wx:if="{{!loading && !userInfo}}">
    <image class="empty-img" src="/assets/images/login-empty.png" />
    <text class="empty-title">未登录</text>
    <text class="empty-desc">登录后获取个性化推荐</text>
    <button class="login-btn" bindtap="navigateToLogin">立即登录</button>
  </view>
</view>