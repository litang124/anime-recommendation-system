<!-- pages/schedule/schedule.wxml -->
<view class="schedule-container">
  <!-- 头部 -->
  <view class="schedule-header">
    <text class="header-title">新番日历</text>
    <text class="header-subtitle">追番不迷路</text>
  </view>

  <!-- 日期选择器 -->
  <scroll-view scroll-x class="date-scroll">
    <view class="date-list">
      <view wx:for="{{dates}}" wx:key="date"
            class="date-item {{selectedDateIndex === index ? 'active' : ''}} {{item.isToday ? 'today' : ''}}"
            data-index="{{index}}"
            bindtap="selectDate">
        <text class="day-text">{{item.day}}</text>
        <text class="date-text">{{item.displayDate}}</text>
        <view class="schedule-dot" wx:if="{{item.hasSchedule}}"></view>
      </view>
    </view>
  </scroll-view>

  <!-- 日程列表 -->
  <view class="schedule-content">
    <!-- 加载中 -->
    <view class="loading-state" wx:if="{{loading}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>

    <!-- 日程卡片 -->
    <view class="schedule-list" wx:if="{{!loading && currentSchedules.length > 0}}">
      <view class="schedule-date-header">
        <text class="date-title">{{currentDate}}</text>
        <text class="schedule-count">{{currentSchedules.length}}部更新</text>
      </view>
      
      <view class="schedule-cards">
        <view class="schedule-card" wx:for="{{currentSchedules}}" wx:key="id"
              bindtap="goToAnimeDetail" data-id="{{item.animeId}}">
          <image class="anime-cover" src="{{item.coverUrl}}" mode="aspectFill"/>
          <view class="schedule-info">
            <text class="anime-title">{{item.title}}</text>
            <view class="schedule-meta">
              <text class="episode">第{{item.episode}}集</text>
              <text class="time">{{item.time}}</text>
            </view>
            <view class="schedule-footer">
              <text class="platform">{{item.platform}}</text>
              <text class="score" wx:if="{{item.score > 0}}">⭐ {{item.score}}</text>
            </view>
          </view>
          <view class="schedule-action">
            <text class="status-badge {{item.status === 1 ? 'aired' : 'pending'}}">
              {{item.status === 1 ? '已播' : '待播'}}
            </text>
            <button class="remind-btn {{item.inWishList ? 'active' : ''}}" catchtap="setReminder" data-id="{{item.id}}">
              {{item.inWishList ? '✅' : '🔔'}}
            </button>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loading && currentSchedules.length === 0}}">
      <text class="empty-icon">📅</text>
      <text class="empty-text">今天没有新番更新</text>
      <text class="empty-tip">看看其他时间吧</text>
    </view>

    <!-- 热门动漫 -->
    <view class="hot-section" wx:if="{{weekHotAnime.length > 0}}">
      <view class="section-header">
        <text class="section-title">🔥 本周热门</text>
      </view>
      <scroll-view scroll-x class="hot-scroll">
        <view class="hot-list">
          <view class="hot-item" wx:for="{{weekHotAnime}}" wx:key="id"
                bindtap="goToAnimeDetail" data-id="{{item.id}}">
            <image class="hot-cover" src="{{item.coverUrl}}" mode="aspectFill"/>
            <view class="hot-rank">TOP{{index + 1}}</view>
            <text class="hot-title">{{item.title}}</text>
            <text class="hot-score">⭐ {{item.score}}</text>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 底部快捷操作 -->
  <view class="quick-actions">
    <button class="action-btn today-btn" bindtap="goToToday">今天</button>
  </view>
</view>
