/* pages/schedule/schedule.wxss */
.schedule-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 头部 */
.schedule-header {
  background: linear-gradient(135deg, #f03d6d 0%, #ff8a65 100%);
  padding: 40rpx;
  text-align: center;
}

.header-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  display: block;
}

.header-subtitle {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 8rpx;
  display: block;
}

/* 日期选择器 */
.date-scroll {
  background: #fff;
  padding: 20rpx 0;
  white-space: nowrap;
}

.date-list {
  display: flex;
  padding: 0 20rpx;
}

.date-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 24rpx;
  margin-right: 16rpx;
  border-radius: 16rpx;
  background: #f5f5f5;
  position: relative;
  min-width: 80rpx;
}

.date-item.active {
  background: linear-gradient(135deg, #f03d6d 0%, #ff8a65 100%);
}

.date-item.today {
  border: 2rpx solid #f03d6d;
}

.date-item.active.today {
  border: none;
}

.day-text {
  font-size: 24rpx;
  color: #999;
}

.date-item.active .day-text {
  color: rgba(255,255,255,0.8);
}

.date-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-top: 4rpx;
}

.date-item.active .date-text {
  color: #fff;
}

.schedule-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #ff6b6b;
  position: absolute;
  top: 8rpx;
  right: 8rpx;
}

.date-item.active .schedule-dot {
  background: #fff;
}

/* 日程内容 */
.schedule-content {
  padding: 20rpx;
}

.schedule-date-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.date-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.schedule-count {
  font-size: 24rpx;
  color: #f03d6d;
  background: rgba(102,126,234,0.1);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

/* 日程卡片 */
.schedule-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.schedule-cards {
  padding: 0 20rpx;
}

.schedule-card {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.schedule-card:last-child {
  border-bottom: none;
}

.anime-cover {
  width: 140rpx;
  height: 180rpx;
  border-radius: 12rpx;
  background: #f0f0f0;
}

.schedule-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.anime-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  line-height: 1.4;
}

.schedule-meta {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
}

.episode {
  font-size: 26rpx;
  color: #f03d6d;
  background: rgba(102,126,234,0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
}

.time {
  font-size: 26rpx;
  color: #666;
}

.schedule-footer {
  display: flex;
  justify-content: space-between;
  margin-top: 12rpx;
}

.platform {
  font-size: 24rpx;
  color: #999;
}

.score {
  font-size: 24rpx;
  color: #ffa502;
}

.schedule-action {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: space-between;
  padding-left: 20rpx;
}

.status-badge {
  font-size: 22rpx;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
}

.status-badge.aired {
  background: #e8f5e9;
  color: #4caf50;
}

.status-badge.pending {
  background: #fff3e0;
  color: #ff9800;
}

.remind-btn {
  width: 60rpx;
  height: 60rpx;
  padding: 0;
  margin: 0;
  background: #f5f5f5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.remind-btn.active {
  background: #e8f5e9;
  border: 2rpx solid #4caf50;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #f03d6d;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #999;
  margin-top: 20rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
  background: #fff;
  border-radius: 16rpx;
}

.empty-icon {
  font-size: 100rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-top: 30rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #999;
  margin-top: 16rpx;
}

/* 热门动漫 */
.hot-section {
  margin-top: 30rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.section-header {
  padding: 24rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.hot-scroll {
  padding: 20rpx;
}

.hot-list {
  display: flex;
}

.hot-item {
  margin-right: 20rpx;
  text-align: center;
  width: 160rpx;
  position: relative;
}

.hot-cover {
  width: 160rpx;
  height: 210rpx;
  border-radius: 12rpx;
  background: #f0f0f0;
}

.hot-rank {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #feca57 100%);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.hot-title {
  font-size: 24rpx;
  color: #333;
  margin-top: 12rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hot-score {
  font-size: 22rpx;
  color: #ffa502;
  margin-top: 4rpx;
  display: block;
}

/* 底部快捷操作 */
.quick-actions {
  position: fixed;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 20rpx;
}

.action-btn {
  padding: 20rpx 40rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.15);
}

.today-btn {
  background: linear-gradient(135deg, #f03d6d 0%, #ff8a65 100%);
  color: #fff;
}
