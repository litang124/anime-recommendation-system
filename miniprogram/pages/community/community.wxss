/* pages/community/community.wxss */
.community-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 头部 */
.community-header {
  background: linear-gradient(135deg, #f03d6d 0%, #ff8a65 100%);
  padding: 40rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-content {
  flex: 1;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  display: block;
}

.subtitle {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 8rpx;
  display: block;
}

.post-btn {
  background: rgba(255,255,255,0.2);
  color: #fff;
  font-size: 28rpx;
  padding: 16rpx 32rpx;
  border-radius: 32rpx;
  border: 2rpx solid rgba(255,255,255,0.3);
}

/* 分类标签 */
.category-scroll {
  background: #fff;
  padding: 20rpx 0;
}

.category-list {
  display: flex;
  padding: 0 20rpx;
}

.category-item {
  padding: 16rpx 32rpx;
  margin-right: 20rpx;
  border-radius: 32rpx;
  background: #f5f5f5;
  white-space: nowrap;
}

.category-item.active {
  background: linear-gradient(135deg, #f03d6d 0%, #ff8a65 100%);
}

.category-item text {
  font-size: 28rpx;
  color: #666;
}

.category-item.active text {
  color: #fff;
  font-weight: 500;
}

/* 统计区域 */
.stats-section {
  display: flex;
  justify-content: space-around;
  background: #fff;
  padding: 30rpx;
  margin: 20rpx;
  border-radius: 16rpx;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #f03d6d;
  display: block;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

/* 区块样式 */
.section {
  background: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.section-header {
  padding: 24rpx;
  border-bottom: 2rpx solid #f5f5f5;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-more {
  font-size: 26rpx;
  color: #666;
  padding: 8rpx 16rpx;
}

/* 热门动漫 */
.hot-anime-section {
  padding-bottom: 20rpx;
}

.anime-scroll {
  padding: 20rpx;
}

.anime-list {
  display: flex;
}

.anime-item {
  margin-right: 20rpx;
  text-align: center;
  width: 180rpx;
}

.anime-cover {
  width: 180rpx;
  height: 240rpx;
  border-radius: 12rpx;
  background: #f0f0f0;
}

.anime-title {
  font-size: 24rpx;
  color: #333;
  margin-top: 12rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.anime-score {
  font-size: 22rpx;
  color: #ffa502;
  margin-top: 4rpx;
  display: block;
}

/* 评论列表 */
.reviews-section {
  padding-bottom: 20rpx;
}

.reviews-list {
  padding: 0 20rpx;
}

.review-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  position: relative;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.hot-badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #feca57 100%);
  color: #fff;
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

/* 用户信息 */
.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #f0f0f0;
}

.user-detail {
  flex: 1;
  margin-left: 20rpx;
}

.user-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  display: block;
}

.review-time {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
  display: block;
}

.rating-badge {
  text-align: right;
}

.rating-stars {
  display: block;
}

.star {
  font-size: 24rpx;
  color: #ddd;
}

.star.active {
  color: #ffa502;
}

.rating-score {
  font-size: 28rpx;
  color: #ffa502;
  font-weight: bold;
  margin-top: 4rpx;
  display: block;
}

/* 评论内容 */
.review-content {
  margin-bottom: 20rpx;
}

.review-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

/* 动漫信息 */
.anime-info {
  display: flex;
  align-items: center;
  background: #f8f9fa;
  padding: 16rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.anime-thumb {
  width: 100rpx;
  height: 130rpx;
  border-radius: 8rpx;
  background: #e0e0e0;
}

.anime-detail {
  flex: 1;
  margin-left: 20rpx;
}

.anime-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: block;
}

.anime-score {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
  display: block;
}

.arrow {
  font-size: 40rpx;
  color: #999;
}

/* 互动按钮 */
.review-actions {
  display: flex;
  border-top: 2rpx solid #f5f5f5;
  padding-top: 20rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
}

.action-btn .icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.action-btn .count {
  font-size: 26rpx;
  color: #666;
}

.action-btn.liked .count {
  color: #f03d6d;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #f03d6d;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #999;
  margin-top: 20rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-top: 30rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #999;
  margin-top: 16rpx;
}
