/* pages/profile/profile.wxss */
.profile-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f03d6d 0%, #ff8a65 200px, #f5f5f5 200px);
  padding-bottom: 40rpx;
}

/* 用户卡片 */
.user-card {
  margin: 20rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
}

.user-header {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.15);
}

.user-info {
  flex: 1;
  margin-left: 30rpx;
}

.user-nickname {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.user-id {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

.login-tip {
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

.settings-btn {
  padding: 20rpx;
  display: flex;
  align-items: center;
}

.settings-btn .icon {
  font-size: 40rpx;
}

.settings-text {
  font-size: 28rpx;
  color: #666;
  margin-left: 12rpx;
}

/* 登录区域 */
.login-section {
  text-align: center;
  padding: 20rpx 0;
}

.login-btn {
  background: linear-gradient(135deg, #f03d6d 0%, #ff8a65 100%);
  color: #fff;
  font-size: 32rpx;
  padding: 24rpx 80rpx;
  border-radius: 40rpx;
  border: none;
}

/* 统计栏 */
.statistics-bar {
  display: flex;
  justify-content: space-around;
  padding-top: 30rpx;
  border-top: 2rpx solid #f0f0f0;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #f03d6d;
  display: block;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
  display: block;
}

/* 标签栏 */
.tab-bar {
  display: flex;
  background: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  position: relative;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.tab-item.active {
  background: linear-gradient(135deg, #f03d6d 0%, #ff8a65 100%);
}

.tab-text {
  font-size: 28rpx;
  color: #666;
}

.tab-item.active .tab-text {
  color: #fff;
  font-weight: 500;
}

.tab-badge {
  position: absolute;
  top: 10rpx;
  right: 20rpx;
  background: #ff4757;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  min-width: 32rpx;
}

/* 内容列表 */
.content-list {
  margin: 0 20rpx;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #f03d6d;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #999;
  margin-top: 20rpx;
}

/* 记录列表 */
.record-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.record-item {
  display: flex;
  padding: 24rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.record-item:last-child {
  border-bottom: none;
}

.record-cover {
  width: 140rpx;
  height: 180rpx;
  border-radius: 12rpx;
  background: #f0f0f0;
}

.record-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.record-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  line-height: 1.4;
}

.record-meta {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
}

.record-score {
  font-size: 26rpx;
  color: #ffa502;
  margin-right: 20rpx;
}

.record-progress {
  font-size: 24rpx;
  color: #666;
}

.record-status {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
}

.status-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.status-0 {
  background: #e3f2fd;
  color: #2196f3;
}

.status-1 {
  background: #e8f5e9;
  color: #4caf50;
}

.status-2 {
  background: #fff3e0;
  color: #ff9800;
}

.update-time {
  font-size: 22rpx;
  color: #999;
}

.record-action {
  padding: 20rpx;
  display: flex;
  align-items: center;
}

.action-icon {
  font-size: 40rpx;
  color: #999;
}

/* 评论列表 */
.review-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.review-item {
  display: flex;
  padding: 24rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.review-item:last-child {
  border-bottom: none;
}

.review-anime-cover {
  width: 120rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: #f0f0f0;
}

.review-content {
  flex: 1;
  margin-left: 24rpx;
}

.review-anime-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  display: block;
}

.review-rating {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
}

.rating-stars {
  font-size: 24rpx;
  color: #ffa502;
  letter-spacing: 4rpx;
}

.rating-value {
  font-size: 26rpx;
  color: #ffa502;
  margin-left: 12rpx;
  font-weight: 500;
}

.review-text {
  font-size: 26rpx;
  color: #666;
  margin-top: 16rpx;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.review-footer {
  display: flex;
  justify-content: space-between;
  margin-top: 16rpx;
}

.review-time {
  font-size: 22rpx;
  color: #999;
}

.review-likes {
  font-size: 22rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
  background: #fff;
  border-radius: 16rpx;
}

.empty-icon {
  font-size: 100rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-top: 30rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #999;
  margin-top: 16rpx;
}

/* 想看清单滚动区域 */
.wish-scroll {
  white-space: nowrap;
  padding: 20rpx 0;
}

.record-item {
  display: inline-block;
  margin-right: 20rpx;
  width: 240rpx;
}

/* 兴趣标签浓度 */
.tag-concentration {
  margin-top: 30rpx;
  padding-top: 30rpx;
  border-top: 2rpx solid #f0f0f0;
}

.section-title {
  margin-bottom: 24rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.tag-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.tag-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.tag-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  flex: 1;
}

.tag-progress {
  flex: 2;
  margin-left: 24rpx;
}

.progress-bar {
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #f03d6d 0%, #ff8a65 100%);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.progress-percent {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
  text-align: right;
}
