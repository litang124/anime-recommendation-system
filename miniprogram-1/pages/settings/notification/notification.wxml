<!--pages/settings/notification/notification.wxml-->
<view class="notification-container">
  <view class="page-title">消息通知</view>
  
  <view class="notification-list">
    <view class="notification-item" wx:for="{{notifications}}" wx:key="id" bindtap="toggleNotification" data-index="{{index}}">
      <view class="notification-content">
        <text class="notification-title">{{item.title}}</text>
        <text class="notification-desc">{{item.desc}}</text>
      </view>
      <view class="notification-toggle">
        <view class="toggle-switch {{item.enabled ? 'on' : 'off'}}">
          <view class="toggle-circle {{item.enabled ? 'on' : 'off'}}"></view>
        </view>
      </view>
    </view>
  </view>
  
  <view class="back-btn" bindtap="goBack">
    <text class="back-text">← 返回</text>
  </view>
</view>