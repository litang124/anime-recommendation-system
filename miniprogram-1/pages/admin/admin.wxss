.container {
  padding: 20rpx;
  background-color: #f8f9fa;
}

.login-form {
  padding: 40rpx 20rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 40rpx;
  color: #333;
  text-align: center;
}

.input-group {
  margin-bottom: 30rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #6c757d;
  margin-bottom: 10rpx;
}

.input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #dee2e6;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.login-btn {
  width: 100%;
  height: 88rpx;
  background: #007bff;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 12rpx;
  margin-top: 20rpx;
}

.loading, .error {
  text-align: center;
  padding: 40rpx 0;
  color: #6c757d;
}

.stats-cards {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.card {
  flex: 1;
  min-width: 200rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
  text-align: center;
}

.card-label {
  font-size: 24rpx;
  color: #6c757d;
  margin-bottom: 10rpx;
}

.card-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin: 40rpx 0 20rpx;
  color: #333;
}

.tag-cloud {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
  margin-bottom: 40rpx;
}

.tag-item {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 20rpx;
  background: #e9ecef;
  border-radius: 40rpx;
  font-size: 24rpx;
  color: #495057;
}

.tag-count {
  margin-left: 10rpx;
  font-weight: bold;
  color: #6c757d;
}