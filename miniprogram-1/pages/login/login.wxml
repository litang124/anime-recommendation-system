<!-- pages/login/login.wxml -->
<view class="login-container">
  <view class="logo-area">
    <text class="logo-icon">🎬</text>
    <text class="app-name">动漫星球</text>
    <text class="app-desc">基于协同过滤的动漫推荐</text>
  </view>
  
  <view class="login-content">
    <view class="welcome-text">
      欢迎来到动漫星球
    </view>
    
    <view class="feature-list">
      <view class="feature-item">🎯 个性化动漫推荐</view>
      <view class="feature-item">📅 新番放送日历</view>
      <view class="feature-item">💬 评分交流社区</view>
      <view class="feature-item">⭐ 收藏观看记录</view>
    </view>
  </view>
  
  <view class="button-area">
    <button 
      class="login-btn primary" 
      bindtap="wxLogin"
      loading="{{loading}}"
      disabled="{{loading}}"
    >
      微信一键登录
    </button>
    
    <button 
      class="login-btn secondary" 
      bindtap="guestLogin"
    >
      游客体验
    </button>
    
    <view class="agreement">
      登录即代表同意
      <text class="link">《用户协议》</text>
      和
      <text class="link">《隐私政策》</text>
    </view>
  </view>
</view>