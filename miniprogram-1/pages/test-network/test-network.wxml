<!-- pages/test-network/test-network.wxml -->
<view class="test-container">
  <!-- 头部 -->
  <view class="test-header">
    <text class="header-title">网络诊断工具</text>
    <text class="header-subtitle">API接口连通性测试</text>
  </view>

  <!-- 环境信息 -->
  <view class="info-section">
    <view class="info-card">
      <view class="info-row">
        <text class="info-label">API地址</text>
        <text class="info-value">{{apiBaseUrl}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">运行环境</text>
        <text class="info-value">{{platform}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">网络状态</text>
        <text class="info-value {{networkType === 'wifi' ? 'success' : 'warning'}}">{{networkType}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">Token状态</text>
        <text class="info-value {{hasToken ? 'success' : 'warning'}}">{{hasToken ? '已登录' : '未登录'}}</text>
      </view>
    </view>
  </view>

  <!-- 测试统计 -->
  <view class="stats-section" wx:if="{{testResults.length > 0}}">
    <view class="stat-item">
      <text class="stat-value">{{testResults.length}}</text>
      <text class="stat-label">已测试</text>
    </view>
    <view class="stat-item">
      <text class="stat-value success">{{successCount}}</text>
      <text class="stat-label">成功</text>
    </view>
    <view class="stat-item">
      <text class="stat-value error">{{failCount}}</text>
      <text class="stat-label">失败</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{avgDuration}}ms</text>
      <text class="stat-label">平均耗时</text>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-section">
    <button class="test-btn primary" bindtap="runAllTests" loading="{{testing}}">
      {{testing ? '测试中...' : '🚀 一键测试全部'}}
    </button>
    <view class="btn-group">
      <button class="test-btn small" bindtap="testBasic" disabled="{{testing}}">基础连接</button>
      <button class="test-btn small" bindtap="testAnime" disabled="{{testing}}">动漫接口</button>
      <button class="test-btn small" bindtap="testSchedule" disabled="{{testing}}">日程接口</button>
    </view>
    <view class="btn-group">
      <button class="test-btn small" bindtap="testUser" disabled="{{testing}}">用户接口</button>
      <button class="test-btn small" bindtap="testReview" disabled="{{testing}}">评论接口</button>
      <button class="test-btn small" bindtap="testRecommend" disabled="{{testing}}">推荐接口</button>
    </view>
    <button class="test-btn warning" bindtap="clearResults" wx:if="{{testResults.length > 0}}">
      🗑️ 清空结果
    </button>
  </view>

  <!-- 测试结果列表 -->
  <view class="results-section">
    <view class="section-title">测试结果</view>
    
    <view class="results-list" wx:if="{{testResults.length > 0}}">
      <view class="result-card {{item.success ? 'success' : 'error'}}" 
            wx:for="{{testResults}}" wx:key="id">
        <view class="result-header">
          <view class="result-icon">
            <text>{{item.success ? '✅' : '❌'}}</text>
          </view>
          <view class="result-title-wrap">
            <text class="result-name">{{item.name}}</text>
            <text class="result-endpoint">{{item.endpoint}}</text>
          </view>
          <text class="result-duration">{{item.duration}}ms</text>
        </view>
        
        <view class="result-body" wx:if="{{item.success}}">
          <view class="result-detail">
            <text class="detail-label">状态码:</text>
            <text class="detail-value">{{item.code}}</text>
          </view>
          <view class="result-detail" wx:if="{{item.dataCount !== undefined}}">
            <text class="detail-label">数据量:</text>
            <text class="detail-value">{{item.dataCount}}</text>
          </view>
        </view>
        
        <view class="result-error" wx:if="{{!item.success}}">
          <text class="error-text">{{item.error}}</text>
        </view>
        
        <!-- 响应数据预览 -->
        <view class="response-preview" wx:if="{{item.success && item.preview}}" bindtap="togglePreview" data-id="{{item.id}}">
          <text class="preview-toggle">{{item.showPreview ? '▼ 收起' : '▶ 展开响应数据'}}</text>
        </view>
        <view class="response-data" wx:if="{{item.success && item.showPreview && item.preview}}">
          <text class="response-text">{{item.preview}}</text>
        </view>
      </view>
    </view>
    
    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{testResults.length === 0 && !testing}}">
      <text class="empty-icon">📡</text>
      <text class="empty-text">暂无测试结果</text>
      <text class="empty-tip">点击上方按钮开始测试</text>
    </view>
    
    <!-- 加载中 -->
    <view class="loading-state" wx:if="{{testing && testResults.length === 0}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">正在测试...</text>
    </view>
  </view>
</view>
