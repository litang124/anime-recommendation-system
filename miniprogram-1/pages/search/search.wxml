<!-- pages/search/search.wxml -->
<view class="search-container">
  <!-- 搜索框 -->
  <view class="search-header">
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input class="search-input" 
             placeholder="搜索动漫名称" 
             value="{{searchKeyword}}"
             bindinput="onInput"
             confirm-type="search"
             bindconfirm="doSearch"/>
      <text class="clear-btn" wx:if="{{searchKeyword}}" bindtap="clearInput">✕</text>
    </view>
    <button class="search-btn" bindtap="doSearch">搜索</button>
  </view>

  <!-- 未搜索时显示历史和热门 -->
  <view class="search-content" wx:if="{{!hasSearched}}">
    <!-- 搜索历史 -->
    <view class="section" wx:if="{{searchHistory.length > 0}}">
      <view class="section-header">
        <text class="section-title">🕐 搜索历史</text>
        <text class="clear-history" bindtap="clearHistory">清空</text>
      </view>
      <view class="history-list">
        <view class="history-item" 
              wx:for="{{searchHistory}}" 
              wx:key="*this"
              data-keyword="{{item}}"
              bindtap="tapHistory">
          <text>{{item}}</text>
        </view>
      </view>
    </view>

    <!-- 热门搜索 -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">🔥 热门搜索</text>
      </view>
      <view class="hot-list">
        <view class="hot-item" 
              wx:for="{{hotKeywords}}" 
              wx:key="*this"
              data-keyword="{{item}}"
              bindtap="tapHot">
          <text class="hot-index {{index < 3 ? 'top' : ''}}">{{index + 1}}</text>
          <text class="hot-text">{{item}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 搜索结果 -->
  <view class="search-results" wx:if="{{hasSearched}}">
    <!-- 加载中 -->
    <view class="loading-state" wx:if="{{loading}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">搜索中...</text>
    </view>

    <!-- 结果列表 -->
    <view class="results-list" wx:if="{{!loading && searchResults.length > 0}}">
      <view class="result-item" 
            wx:for="{{searchResults}}" 
            wx:key="id"
            data-id="{{item.id}}"
            bindtap="goToDetail">
        <image class="result-cover" src="{{item.coverUrl}}" mode="aspectFill"/>
        <view class="result-info">
          <text class="result-title">{{item.title}}</text>
          <view class="result-meta">
            <text class="result-score">⭐ {{item.score}}</text>
            <text class="result-status">{{item.status}}</text>
            <text class="result-episodes">{{item.episodeCount}}集</text>
          </view>
          <view class="result-tags">
            <text class="tag" wx:for="{{item.tags}}" wx:key="*this" wx:for-item="tag">{{tag}}</text>
          </view>
        </view>
        <text class="arrow">›</text>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loading && searchResults.length === 0}}">
      <text class="empty-icon">🔍</text>
      <text class="empty-text">未找到相关动漫</text>
      <text class="empty-tip">换个关键词试试吧</text>
    </view>

    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{searchResults.length > 0 && hasMore}}">
      <text class="load-more-text" wx:if="{{!loading}}">上拉加载更多</text>
      <view class="loading-spinner small" wx:if="{{loading}}"></view>
    </view>
    
    <view class="no-more" wx:if="{{searchResults.length > 0 && !hasMore}}">
      <text>没有更多了</text>
    </view>
  </view>
</view>
