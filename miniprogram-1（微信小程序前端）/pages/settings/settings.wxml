<!--pages/settings/settings.wxml-->
<view class="settings-container">
  <!-- 用户信息卡片 -->
  <view class="user-card" wx:if="{{isLoggedIn}}">
    <view class="user-header">
      <image class="user-avatar" src="{{userInfo.avatarUrl || '/images/logo.png'}}" mode="aspectFill"/>
      <view class="user-info">
        <text class="user-nickname">{{userInfo.nickname || '用户'}}</text>
        <text class="user-id">ID: {{userInfo.id}}</text>
      </view>
    </view>
    <view class="logout-btn" bindtap="logout">
      <text class="logout-text">退出登录</text>
    </view>
  </view>

  <!-- 设置列表 -->
  <view class="settings-list">
    <view class="setting-item" wx:for="{{settings}}" wx:key="id" bindtap="goToSettingDetail" data-id="{{item.id}}">
      <view class="setting-icon">{{item.icon}}</view>
      <view class="setting-content">
        <text class="setting-title">{{item.title}}</text>
        <text class="setting-desc">{{item.desc}}</text>
      </view>
      <view class="setting-arrow">→</view>
    </view>
  </view>

  <!-- 未登录提示 -->
  <view class="login-prompt" wx:if="{{!isLoggedIn}}">
    <text class="prompt-text">请先登录以使用设置功能</text>
    <button class="login-btn" bindtap="goToLogin">立即登录</button>
  </view>
</view>