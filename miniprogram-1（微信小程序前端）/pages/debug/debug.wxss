.container {
  padding: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
  text-align: center;
}

.info-card {
  background: #f5f5f5;
  border-radius: 10rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.info-label {
  font-weight: bold;
  color: #666;
}

.info-value {
  color: #333;
  margin-left: 10rpx;
}

.btn-group {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin: 30rpx 0;
}

button {
  width: 100%;
}

.results {
  margin-top: 40rpx;
}

.result-title {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.result-item {
  padding: 20rpx;
  border-radius: 10rpx;
  margin-bottom: 10rpx;
}

.result-item.success {
  background: #e8f5e9;
  border: 1rpx solid #4caf50;
}

.result-item.error {
  background: #ffebee;
  border: 1rpx solid #f44336;
}

.result-text {
  color: #333;
}